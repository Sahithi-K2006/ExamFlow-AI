{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "backend/venv/bin/uvicorn app.main:app --reload --port ${PORT:-8000} --app-dir backend"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
