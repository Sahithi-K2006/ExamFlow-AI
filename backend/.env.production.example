# Production environment template. Copy to .env on the production host/container
# and fill in every value below — nothing here should be left at its placeholder.

# Supabase Postgres connection string. Find it in your Supabase project:
# Project Settings -> Database -> Connection string (URI format, "Session pooler"
# for most PaaS hosts). Leave empty until you have a real project — the app
# will fail to start without a valid DATABASE_URL in production.
DATABASE_URL=

# Managed or self-hosted Redis. Supabase has no managed Redis — use a provider
# like Upstash/Redis Cloud, or self-host alongside the backend container.
REDIS_URL=redis://localhost:6379/0

# JWT — generate a real random secret, e.g. `openssl rand -hex 32`. Never reuse
# the dev default.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Super admin seeded via `python -m scripts.seed_admin` — change the password
# from any value used in development.
ADMIN_EMAIL=admin@examflow.ai
ADMIN_PASSWORD=
ADMIN_NAME=Root Administrator

# Comma-separated list of the real frontend origin(s) serving this app.
FRONTEND_ORIGIN=https://your-production-domain.com

# Supabase Storage (question images/attachments). Project Settings -> API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=exam-attachments

# Waiting Lounge AI Assistant (POST /api/ai/chat). platform.openai.com/api-keys.
# Leave empty to disable the assistant — it degrades to a friendly 503, the app still boots.
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
TEMPERATURE=0.3
MAX_TOKENS=700
