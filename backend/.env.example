# Database — local dev uses MySQL. Both drivers (pymysql + psycopg2-binary) are installed,
# so cutting over to Supabase later is just swapping this one line for the Postgres URL below.
DATABASE_URL=mysql+pymysql://examflow:examflow_dev_pw@127.0.0.1:3306/examflow_ai
# DATABASE_URL=postgresql+psycopg2://postgres:<password>@<project-ref>.supabase.co:5432/postgres

# Redis — self-hosted, not part of the Supabase migration (Supabase has no managed Redis).
REDIS_URL=redis://127.0.0.1:6379/0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Predefined super admin credentials (seeded/updated via `python -m scripts.seed_admin`).
# Change this password before deploying anywhere but local dev.
ADMIN_EMAIL=admin@examflow.ai
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Root Administrator

# CORS — comma-separated list of allowed frontend origins, e.g.
# FRONTEND_ORIGIN=http://localhost:5173,https://app.examflow.ai
FRONTEND_ORIGIN=http://localhost:5173

# Supabase Storage — used for question image/attachment uploads
# (POST /api/admin/questions/{id}/image). Leave unset locally: uploads return
# 503 "Storage is not configured yet" until these are filled in with a real project.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_STORAGE_BUCKET=exam-attachments
